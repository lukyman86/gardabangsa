<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Garda Bangsa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; }
        .card { box-shadow: 0 10px 30px rgba(0,0,0,0.2); border: none; }
        .btn-login { background: #667eea; border: none; font-weight: bold; }
        .btn-login:hover { background: #5568d3; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body p-5">
                        <h3 class="card-title text-center mb-4">🏛️ Garda Bangsa Papua Barat</h3>
                        <h5 class="card-title text-center mb-4 text-muted">Login</h5>
                        
                        <% if (error) { %>
                            <div class="alert alert-danger" role="alert"><%= error %></div>
                        <% } %>
                        
                        <form method="POST">
                            <input type="hidden" name="redirect" value="<%= redirect %>">
                            
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                            
                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input type="password" class="form-control" id="password" name="password" required>
                            </div>
                            
                            <button type="submit" class="btn btn-login w-100 mb-3">Login</button>
                            
                            <div class="text-center">
                                <p class="text-muted">Belum punya akun? <a href="/auth/register">Daftar di sini</a></p>
                                <p><a href="/auth/forgot-password" class="text-decoration-none">Lupa password?</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>