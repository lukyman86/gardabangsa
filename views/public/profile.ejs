<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profil Organisasi - Garda Bangsa Papua Barat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../layouts/header') %>
    
    <main>
        <!-- Page Title -->
        <section class="py-5 bg-dark text-white">
            <div class="container">
                <h1>Profil Organisasi</h1>
            </div>
        </section>
        
        <!-- Vision & Mission -->
        <section class="py-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <h3>Visi</h3>
                        <p>Menjadi organisasi yang kuat dalam memperjuangkan nilai-nilai demokrasi dan persatuan di Papua Barat.</p>
                    </div>
                    <div class="col-md-6 mb-4">
                        <h3>Misi</h3>
                        <ul>
                            <li>Memperkuat pemahaman nilai-nilai nasionalisme</li>
                            <li>Mengembangkan kapasitas anggota organisasi</li>
                            <li>Berkomitmen pada kepentingan masyarakat Papua Barat</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- Management Structure -->
        <section class="py-5 bg-light">
            <div class="container">
                <h2 class="mb-4">Susunan Pengurus</h2>
                <div class="row">
                    <% management.forEach(member => { %>
                        <div class="col-md-4 mb-4">
                            <div class="card text-center">
                                <% if (member.photo_url) { %>
                                    <img src="<%= member.photo_url %>" class="card-img-top" alt="<%= member.name %>">
                                <% } else { %>
                                    <div class="card-img-top bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                                        <span class="text-white">Foto Tidak Tersedia</span>
                                    </div>
                                <% } %>
                                <div class="card-body">
                                    <h5 class="card-title"><%= member.name %></h5>
                                    <p class="card-text text-muted"><%= member.position %></p>
                                    <small class="text-muted">Periode: <%= member.period %></small>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </section>
        
        <!-- Programs -->
        <section class="py-5">
            <div class="container">
                <h2 class="mb-4">Program Kerja</h2>
                <% programs.forEach(program => { %>
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title"><%= program.title %></h5>
                                    <p class="card-text"><%= program.description %></p>
                                    <div class="d-flex justify-content-between">
                                        <span class="badge bg-info"><%= program.status %></span>
                                        <span class="text-muted"><%= new Date(program.target_date).toLocaleDateString('id-ID') %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>
    </main>
    
    <%- include('../layouts/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>