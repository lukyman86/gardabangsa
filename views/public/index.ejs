<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beranda - Garda Bangsa Papua Barat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../layouts/header') %>
    
    <main>
        <!-- Hero Section -->
        <section class="py-5 bg-primary text-white text-center">
            <div class="container">
                <h1 class="display-4 fw-bold mb-3">🏛️ Garda Bangsa Papua Barat</h1>
                <p class="lead">Organisasi Gerakan Rakyat Demokratik Anti Komunis</p>
            </div>
        </section>
        
        <!-- Latest News Section -->
        <section class="py-5">
            <div class="container">
                <h2 class="mb-4">📰 Berita Terbaru</h2>
                <div class="row">
                    <% latestNews.forEach(news => { %>
                        <div class="col-md-4 mb-4">
                            <div class="card h-100">
                                <img src="<%= news.image_url || '/images/placeholder.jpg' %>" class="card-img-top" alt="<%= news.title %>">
                                <div class="card-body">
                                    <h5 class="card-title"><%= news.title %></h5>
                                    <p class="card-text text-muted"><small><%= new Date(news.created_at).toLocaleDateString('id-ID') %></small></p>
                                </div>
                                <div class="card-footer bg-white border-top-0">
                                    <a href="/news/<%= news.slug %>" class="btn btn-sm btn-primary">Baca Selengkapnya</a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
                <div class="text-center mt-4">
                    <a href="/news" class="btn btn-outline-primary btn-lg">Lihat Semua Berita</a>
                </div>
            </div>
        </section>
        
        <!-- Gallery Section -->
        <section class="py-5 bg-light">
            <div class="container">
                <h2 class="mb-4">🎞️ Galeri Kegiatan</h2>
                <div class="row">
                    <% gallery.forEach(photo => { %>
                        <div class="col-md-4 mb-3">
                            <img src="<%= photo.image_url %>" class="img-fluid rounded" alt="<%= photo.title %>">
                        </div>
                    <% }); %>
                </div>
                <div class="text-center mt-4">
                    <a href="/gallery" class="btn btn-outline-primary btn-lg">Lihat Galeri Lengkap</a>
                </div>
            </div>
        </section>
    </main>
    
    <%- include('../layouts/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>