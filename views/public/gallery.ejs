<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galeri - Garda Bangsa Papua Barat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../layouts/header') %>
    
    <main>
        <!-- Page Title -->
        <section class="py-5 bg-dark text-white">
            <div class="container">
                <h1>Galeri Kegiatan</h1>
            </div>
        </section>
        
        <!-- Gallery Grid -->
        <section class="py-5">
            <div class="container">
                <div class="row g-4">
                    <% photos.forEach(photo => { %>
                        <div class="col-md-4">
                            <div class="card h-100">
                                <img src="<%= photo.image_url %>" class="card-img-top" alt="<%= photo.title %>" style="height: 250px; object-fit: cover;">
                                <div class="card-body">
                                    <h5 class="card-title"><%= photo.title %></h5>
                                    <p class="card-text text-muted"><%= photo.description %></p>
                                    <small class="text-muted"><%= new Date(photo.created_at).toLocaleDateString('id-ID') %></small>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
                <% if (photos.length === 0) { %>
                    <div class="alert alert-info text-center mt-4">Belum ada foto di galeri</div>
                <% } %>
            </div>
        </section>
    </main>
    
    <%- include('../layouts/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>