<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Berita - Garda Bangsa Papua Barat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../layouts/header') %>
    
    <main>
        <!-- Page Title -->
        <section class="py-5 bg-dark text-white">
            <div class="container">
                <h1>Berita & Informasi</h1>
            </div>
        </section>
        
        <!-- News List -->
        <section class="py-5">
            <div class="container">
                <% articles.forEach(article => { %>
                    <div class="row mb-5 pb-4 border-bottom">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <img src="<%= article.image_url || '/images/placeholder.jpg' %>" class="img-fluid rounded" alt="<%= article.title %>">
                        </div>
                        <div class="col-md-8">
                            <h3><a href="/news/<%= article.slug %>" class="text-decoration-none"><%= article.title %></a></h3>
                            <p class="text-muted">
                                <small>
                                    <span class="badge bg-secondary"><%= article.category %></span>
                                    <%= new Date(article.created_at).toLocaleDateString('id-ID') %>
                                </small>
                            </p>
                            <p><%= article.content.substring(0, 200) %>...</p>
                            <a href="/news/<%= article.slug %>" class="btn btn-primary btn-sm">Baca Selengkapnya</a>
                        </div>
                    </div>
                <% }); %>
                <% if (articles.length === 0) { %>
                    <div class="alert alert-info text-center">Belum ada berita</div>
                <% } %>
            </div>
        </section>
    </main>
    
    <%- include('../layouts/footer') %>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>